<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Dark palette. Accent matches the Q+ app icon (#2D8CFF). -->
    <SolidColorBrush x:Key="Brush.Bg"          Color="#FF1E1E1E"/>
    <SolidColorBrush x:Key="Brush.Panel"       Color="#FF252526"/>
    <SolidColorBrush x:Key="Brush.Border"      Color="#FF3F3F46"/>
    <SolidColorBrush x:Key="Brush.Text"        Color="#FFE6E6E6"/>
    <SolidColorBrush x:Key="Brush.Subtle"      Color="#FF9A9A9A"/>
    <SolidColorBrush x:Key="Brush.Accent"      Color="#FF2D8CFF"/>
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#FF57A6FF"/>
    <SolidColorBrush x:Key="Brush.Control"     Color="#FF2D2D30"/>
    <SolidColorBrush x:Key="Brush.ControlText" Color="#FFE6E6E6"/>
    <SolidColorBrush x:Key="Brush.Hover"       Color="#FF37373D"/>
    <SolidColorBrush x:Key="Brush.SelectionBg" Color="#FF094771"/>
    <SolidColorBrush x:Key="Brush.EditorBg"    Color="#FF1B1B1C"/>
    <SolidColorBrush x:Key="Brush.EditorText"  Color="#FFE6E6E6"/>
    <SolidColorBrush x:Key="Brush.GridBg"      Color="#FF1E1E1E"/>
    <SolidColorBrush x:Key="Brush.GridText"    Color="#FFE6E6E6"/>
    <SolidColorBrush x:Key="Brush.GridHeader"  Color="#FF2D2D30"/>
</ResourceDictionary>
