<Window x:Class="Qplus.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Qplus.App.ViewModels"
        Title="Qplus" Height="760" Width="1180"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/qplus.ico"
        Background="{DynamicResource Brush.Bg}"
        Foreground="{DynamicResource Brush.Text}">

    <DockPanel>
        <!-- ===== Menu ===== -->
        <Menu DockPanel.Dock="Top" Background="{DynamicResource Brush.Panel}" Foreground="{DynamicResource Brush.Text}">
            <MenuItem Header="_File">
                <MenuItem Header="_New Query Tab" InputGestureText="Ctrl+N" Click="NewQuery_Click"/>
                <MenuItem Header="_Open .sql…" Click="OpenSql_Click"/>
                <MenuItem Header="_Save .sql…" Click="SaveSqlFile_Click"/>
                <Separator/>
                <MenuItem Header="_Close Tab" InputGestureText="Ctrl+W" Click="CloseTab_Click"/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Connections">
                <MenuItem Header="_Add connection…" Click="AddConnection_Click"/>
                <MenuItem Header="_Edit selected…" Click="EditConnection_Click"/>
                <MenuItem Header="_Remove selected" Click="RemoveConnection_Click"/>
                <Separator/>
                <MenuItem Header="_Refresh object explorer" Click="RefreshExplorer_Click"/>
            </MenuItem>
            <MenuItem Header="_Query">
                <MenuItem Header="_Execute" InputGestureText="F5" Click="Execute_Click"/>
                <MenuItem Header="Execute _selection" InputGestureText="Ctrl+F5" Click="ExecuteSelection_Click"/>
                <MenuItem Header="_Cancel" Click="CancelQuery_Click"/>
                <Separator/>
                <MenuItem Header="_Save query to library…" Click="SaveQuery_Click"/>
                <Separator/>
                <MenuItem Header="S_ync queries with server" Click="SyncQueries_Click"/>
                <MenuItem Header="_Full sync (exchange everything)" Click="SyncQueriesFull_Click"/>
                <MenuItem Header="Sync se_ttings…" Click="SyncSettings_Click"/>
                <MenuItem Header="_Encryption…" Click="Encryption_Click"/>
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="Open table _details" Click="OpenDetails_Click"/>
                <MenuItem Header="Open in _query editor" Click="OpenInQueryEditor_Click"/>
                <Separator/>
                <MenuItem Header="Table _Designer…" Click="TableDesigner_Click"/>
                <MenuItem Header="_Clone Table…" Click="CloneTable_Click"/>
                <MenuItem Header="_User Management…" Click="UserManagement_Click"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem x:Name="DarkThemeItem" Header="_Dark theme" IsCheckable="True" Click="Theme_Click"/>
                <MenuItem x:Name="LightThemeItem" Header="_Light theme" IsCheckable="True" Click="Theme_Click"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About Qplus" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- ===== Toolbar ===== -->
        <ToolBarTray DockPanel.Dock="Top" Background="{DynamicResource Brush.Panel}">
            <ToolBar Background="{DynamicResource Brush.Panel}">
                <Button Content="＋ New Query" Click="NewQuery_Click" Padding="6,2"/>
                <Button Content="▶ Execute (F5)" Click="Execute_Click" Margin="6,0" Padding="6,2"/>
                <Separator/>
                <TextBlock Text="Saved:" VerticalAlignment="Center" Margin="4,0"
                           Foreground="{DynamicResource Brush.Text}"/>
                <ComboBox x:Name="SavedQueryCombo" Width="240" IsEditable="True" StaysOpenOnEdit="True"
                          IsTextSearchEnabled="False"
                          KeyUp="SavedQueryCombo_KeyUp"
                          SelectionChanged="SavedQueryCombo_SelectionChanged"
                          ToolTip="Type to search saved queries by name or tag; pick one to load it into a new tab"/>
                <Button Content="Save…" Click="SaveQuery_Click" Padding="6,2"
                        ToolTip="Save the active tab's SQL to the query library"/>
                <Button Content="Delete" Click="DeleteSavedQuery_Click" Padding="6,2"
                        ToolTip="Delete the selected saved query"/>
                <Button x:Name="SyncButton" Content="⟲ Sync" Click="SyncQueries_Click" Padding="6,2" Margin="6,0,0,0"
                        ToolTip="Two-way sync of the saved-query library with the central server"/>
            </ToolBar>
        </ToolBarTray>

        <!-- ===== Status bar ===== -->
        <StatusBar DockPanel.Dock="Bottom" Background="{DynamicResource Brush.Panel}" Foreground="{DynamicResource Brush.Text}">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Ready" Foreground="{DynamicResource Brush.Text}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ===== Body ===== -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="180"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Object explorer -->
            <DockPanel Grid.Column="0" Background="{DynamicResource Brush.Panel}">
                <TextBlock DockPanel.Dock="Top" Text="Object Explorer" FontWeight="Bold" Margin="8,6"
                           Foreground="{DynamicResource Brush.Text}"/>
                <TreeView x:Name="ExplorerTree" Background="{DynamicResource Brush.Panel}"
                          BorderThickness="0" Foreground="{DynamicResource Brush.Text}"
                          MouseDoubleClick="ExplorerTree_DoubleClick">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.Resources>
                        <HierarchicalDataTemplate DataType="{x:Type vm:ExplorerNode}" ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Icon}" Margin="0,0,4,0"/>
                                <TextBlock Text="{Binding Header}"/>
                                <TextBlock Text="{Binding Detail}" Opacity="0.6" Margin="8,0,0,0"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.Resources>
                </TreeView>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="{DynamicResource Brush.Border}"/>

            <!-- Query document tabs -->
            <TabControl Grid.Column="2" x:Name="DocTabs" Background="{DynamicResource Brush.Bg}"/>
        </Grid>
    </DockPanel>
</Window>
