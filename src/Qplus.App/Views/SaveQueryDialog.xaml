<Window x:Class="Qplus.App.Views.SaveQueryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Save query" Height="310" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource Brush.Panel}"
        Foreground="{DynamicResource Brush.Text}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Name" Foreground="{DynamicResource Brush.Text}"/>
        <TextBox Grid.Row="1" x:Name="NameBox" Margin="0,4,0,10" Padding="4,3"/>

        <TextBlock Grid.Row="2" Text="Tags (space or comma separated — used for search)"
                   Foreground="{DynamicResource Brush.Text}"/>
        <TextBox Grid.Row="3" x:Name="TagsBox" Margin="0,4,0,10" Padding="4,3"/>

        <TextBlock Grid.Row="4" Text="Runs against"
                   Foreground="{DynamicResource Brush.Text}"/>
        <ComboBox Grid.Row="5" x:Name="ScopeBox" Margin="0,4,0,4"
                  ToolTip="Marks whether this query is portable or uses dialect-specific syntax"/>
        <TextBlock Grid.Row="6" x:Name="ScopeHint" Margin="0,0,0,8" FontSize="11"
                   Opacity="0.75" TextWrapping="Wrap"
                   Foreground="{DynamicResource Brush.Text}"/>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save" Width="80" Margin="4,0" Padding="0,4" Click="Save_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="80" Margin="4,0" Padding="0,4" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
