<Window x:Class="Qplus.App.Views.ConnectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connection" Height="480" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource Brush.Panel}"
        Foreground="{DynamicResource Brush.Text}">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Padding" Value="4,3"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Padding" Value="4,3"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Display name"/>
            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="NameBox"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Engine"/>
            <ComboBox  Grid.Row="1" Grid.Column="1" x:Name="EngineBox" Margin="0,4"
                       SelectionChanged="EngineBox_SelectionChanged"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Host / Server"/>
            <TextBox   Grid.Row="2" Grid.Column="1" x:Name="HostBox"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Port"/>
            <TextBox   Grid.Row="3" Grid.Column="1" x:Name="PortBox"
                       ToolTip="Leave blank for the engine default (SQL 1433 dynamic, Oracle 1521)."/>

            <TextBlock Grid.Row="4" Grid.Column="0" x:Name="DbLabel" Text="Database"/>
            <TextBox   Grid.Row="4" Grid.Column="1" x:Name="DbBox"/>

            <CheckBox  Grid.Row="5" Grid.Column="1" x:Name="OracleSidBox"
                       Content="Treat as SID (instead of service name)" Visibility="Collapsed"/>

            <CheckBox  Grid.Row="6" Grid.Column="1" x:Name="IntegratedBox"
                       Content="Use Windows / integrated authentication"
                       Checked="IntegratedBox_Toggled" Unchecked="IntegratedBox_Toggled"/>

            <TextBlock Grid.Row="7" Grid.Column="0" Text="Username"/>
            <TextBox   Grid.Row="7" Grid.Column="1" x:Name="UserBox"/>

            <TextBlock Grid.Row="8" Grid.Column="0" Text="Password"/>
            <PasswordBox Grid.Row="8" Grid.Column="1" x:Name="PwdBox"/>
        </Grid>

        <CheckBox Grid.Row="2" x:Name="TrustCertBox" Margin="0,8"
                  Content="Trust server certificate (SQL Server)"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                       Margin="0,0,12,0" TextTrimming="CharacterEllipsis" MaxWidth="150"/>
            <Button Content="Test" Width="80" Margin="4,0" Padding="0,4" Click="Test_Click"/>
            <Button Content="Save" Width="80" Margin="4,0" Padding="0,4" Click="Save_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="80" Margin="4,0" Padding="0,4" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
