<Window x:Class="Qplus.App.Views.TableDesignerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Table Designer" Height="520" Width="760"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Panel}"
        Foreground="{DynamicResource Brush.Text}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Schema" VerticalAlignment="Center" Margin="0,0,6,0"
                       Foreground="{DynamicResource Brush.Text}"/>
            <TextBox x:Name="SchemaBox" Width="140" Padding="4,3"/>
            <TextBlock Text="Table name" VerticalAlignment="Center" Margin="16,0,6,0"
                       Foreground="{DynamicResource Brush.Text}"/>
            <TextBox x:Name="TableNameBox" Width="220" Padding="4,3"/>
            <TextBlock x:Name="EngineLabel" VerticalAlignment="Center" Margin="16,0,0,0"
                       Opacity="0.7" Foreground="{DynamicResource Brush.Text}"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
            <Button Content="Add column" Click="AddColumn_Click" Padding="8,3" Margin="0,0,6,0"/>
            <Button Content="Remove selected" Click="RemoveColumn_Click" Padding="8,3" Margin="0,0,6,0"/>
            <Button x:Name="LoadColumnsButton" Content="Load existing columns" Click="LoadColumns_Click"
                    Padding="8,3"/>
        </StackPanel>

        <DataGrid Grid.Row="2" x:Name="ColumnsGrid" AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  HeadersVisibility="All" GridLinesVisibility="All">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                <DataGridComboBoxColumn Header="Type" x:Name="TypeColumn"
                                        SelectedItemBinding="{Binding DataType}" Width="1.4*"/>
                <DataGridTextColumn Header="Length/Prec" Binding="{Binding Length}" Width="*"/>
                <DataGridCheckBoxColumn Header="Null" Binding="{Binding Nullable}" Width="60"/>
                <DataGridCheckBoxColumn Header="PK" Binding="{Binding PrimaryKey}" Width="50"/>
                <DataGridTextColumn Header="Default" Binding="{Binding Default}" Width="1.4*"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="3" x:Name="StatusText" Margin="0,8,0,0"
                   Foreground="{DynamicResource Brush.Text}" TextWrapping="Wrap"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Generate CREATE" Click="GenerateCreate_Click" Width="140" Margin="4,0" Padding="0,5"/>
            <Button Content="Generate ALTER ADD" Click="GenerateAlter_Click" Width="150" Margin="4,0" Padding="0,5"/>
            <Button Content="Cancel" Click="Cancel_Click" Width="90" Margin="4,0" Padding="0,5" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
