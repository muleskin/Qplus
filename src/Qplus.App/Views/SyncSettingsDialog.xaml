<Window x:Class="Qplus.App.Views.SyncSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Query sync settings" Height="360" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource Brush.Panel}"
        Foreground="{DynamicResource Brush.Text}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Central query server" FontWeight="Bold"
                   Foreground="{DynamicResource Brush.Text}"/>
        <TextBlock Grid.Row="1" Margin="0,4,0,10" TextWrapping="Wrap" Opacity="0.8"
                   Foreground="{DynamicResource Brush.Text}"
                   Text="Saved queries are shared through this server. Leave the default unless your team runs its own."/>

        <TextBlock Grid.Row="2" Text="Server address" Foreground="{DynamicResource Brush.Text}"/>
        <TextBox Grid.Row="3" x:Name="UrlBox" Margin="0,4,0,10" Padding="4,3"
                 ToolTip="For example https://oillie.cloud or http://192.168.1.50:5080"/>

        <TextBlock Grid.Row="4" Text="API key (leave blank if the server does not require one)"
                   Foreground="{DynamicResource Brush.Text}"/>
        <PasswordBox Grid.Row="5" x:Name="KeyBox" Margin="0,4,0,10" Padding="4,3"/>

        <TextBlock Grid.Row="6" x:Name="StatusText" TextWrapping="Wrap" Margin="0,4,0,0"
                   Foreground="{DynamicResource Brush.Text}"/>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Reset to default" Click="ResetDefault_Click" Width="120" Margin="4,0" Padding="0,5"/>
            <Button Content="Test" Click="Test_Click" Width="80" Margin="4,0" Padding="0,5"/>
            <Button Content="Save" Click="Save_Click" Width="80" Margin="4,0" Padding="0,5" IsDefault="True"/>
            <Button Content="Cancel" Click="Cancel_Click" Width="80" Margin="4,0" Padding="0,5" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
