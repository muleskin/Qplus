<UserControl x:Class="Qplus.App.Views.QueryDocumentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
             Background="{DynamicResource Brush.Bg}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*" MinHeight="100"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="3*" MinHeight="100"/>
        </Grid.RowDefinitions>

        <!-- Per-document action bar -->
        <Border Grid.Row="0" Background="{DynamicResource Brush.Panel}" Padding="4"
                BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Connection:" VerticalAlignment="Center" Margin="4,0"
                           Foreground="{DynamicResource Brush.Text}"/>
                <ComboBox x:Name="ConnectionCombo" Width="200" VerticalAlignment="Center"
                          ToolTip="Connection this query runs against"/>
                <Button Content="▶ Execute (F5)" Click="Execute_Click" Margin="6,0" Padding="6,2"/>
                <Button Content="■ Cancel" Click="Cancel_Click" Padding="6,2"/>
                <Separator Margin="6,0"/>
                <CheckBox x:Name="ResultsAsTextBox" Content="Results as text" VerticalAlignment="Center"
                          Foreground="{DynamicResource Brush.Text}" Margin="4,0"/>
                <Button Content="Export CSV…" Click="ExportCsv_Click" Margin="6,0" Padding="6,2"
                        ToolTip="Export the selected result grid to a CSV file"/>
                <TextBlock x:Name="StatsText" VerticalAlignment="Center" Margin="10,0"
                           Foreground="{DynamicResource Brush.Text}" Opacity="0.8"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
            <avalonEdit:TextEditor x:Name="Editor"
                                   FontFamily="Consolas" FontSize="13"
                                   ShowLineNumbers="True"
                                   SyntaxHighlighting="TSQL"
                                   Background="{DynamicResource Brush.EditorBg}"
                                   Foreground="{DynamicResource Brush.EditorText}"
                                   WordWrap="False"/>
        </Border>

        <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch"
                      Background="{DynamicResource Brush.Border}"/>

        <TabControl Grid.Row="3" x:Name="ResultTabs" Background="{DynamicResource Brush.Panel}"/>
    </Grid>
</UserControl>
