<Window x:Class="Qplus.App.Views.FolderPromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Move to folder" Height="230" Width="430"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource Brush.Panel}"
        Foreground="{DynamicResource Brush.Text}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Folder" Foreground="{DynamicResource Brush.Text}"/>
        <ComboBox Grid.Row="1" x:Name="FolderBox" Margin="0,4,0,2" IsEditable="True"
                  ToolTip="Pick an existing folder or type a new name. Leave blank for none."/>
        <TextBlock Grid.Row="2" Margin="0,0,0,8" FontSize="11" Opacity="0.75" TextWrapping="Wrap"
                   Foreground="{DynamicResource Brush.Text}"
                   Text="Choose a folder or type a new one. Use / to nest, e.g. Reporting/Monthly. Leave blank to remove the queries from any folder."/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Move" Width="80" Margin="4,0" Padding="0,4" Click="Ok_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="80" Margin="4,0" Padding="0,4" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
