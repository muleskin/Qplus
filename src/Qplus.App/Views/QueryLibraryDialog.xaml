<Window x:Class="Qplus.App.Views.QueryLibraryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Query library" Height="640" Width="1040"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Panel}"
        Foreground="{DynamicResource Brush.Text}">
    <DockPanel Margin="12">

        <!-- ===== toolbar ===== -->
        <Border DockPanel.Dock="Top" Padding="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Find:" VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="{DynamicResource Brush.Text}"/>
                <TextBox x:Name="SearchBox" Width="220" Padding="4,3" TextChanged="Filter_Changed"
                         ToolTip="Matches the name, tags and SQL text"/>

                <TextBlock Text="Runs against:" VerticalAlignment="Center" Margin="14,0,6,0"
                           Foreground="{DynamicResource Brush.Text}"/>
                <ComboBox x:Name="ScopeFilter" Width="150" SelectionChanged="Filter_Changed"/>

                <CheckBox x:Name="ShowDeletedBox" Content="Show deleted" VerticalAlignment="Center"
                          Margin="14,0,0,0" Foreground="{DynamicResource Brush.Text}"
                          Checked="ShowDeleted_Changed" Unchecked="ShowDeleted_Changed"
                          ToolTip="Deleted queries are kept until they sync, so they can be restored"/>

                <Button Content="⟲ Sync now" Click="Sync_Click" Margin="14,0,0,0" Padding="8,2"/>
            </StackPanel>
        </Border>

        <!-- ===== status bar ===== -->
        <Border DockPanel.Dock="Bottom" Padding="0,8,0,0">
            <DockPanel>
                <TextBlock x:Name="StatusText" VerticalAlignment="Center" Opacity="0.85"
                           Foreground="{DynamicResource Brush.Text}" TextTrimming="CharacterEllipsis"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                    <Button Content="Close" Width="90" Margin="4,0" Padding="0,5" Click="Close_Click" IsCancel="True"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ===== actions ===== -->
        <Border DockPanel.Dock="Right" Width="170" Padding="10,0,0,0">
            <StackPanel>
                <TextBlock Text="Selected" FontWeight="Bold" Margin="0,0,0,6"
                           Foreground="{DynamicResource Brush.Text}"/>
                <Button x:Name="OpenButton" Content="Open in editor" Click="Open_Click" Margin="0,0,0,5" Padding="0,5"/>
                <Button x:Name="PropsButton" Content="Edit properties…" Click="Properties_Click" Margin="0,0,0,5" Padding="0,5"/>
                <Button x:Name="DuplicateButton" Content="Duplicate" Click="Duplicate_Click" Margin="0,0,0,5" Padding="0,5"/>
                <Button x:Name="DeleteButton" Content="Delete" Click="Delete_Click" Margin="0,0,0,5" Padding="0,5"/>
                <Button x:Name="RestoreButton" Content="Restore" Click="Restore_Click" Margin="0,0,0,5" Padding="0,5"
                        Visibility="Collapsed"/>

                <Separator Margin="0,8"/>
                <TextBlock Text="Set scope" FontWeight="Bold" Margin="0,0,0,6"
                           Foreground="{DynamicResource Brush.Text}"/>
                <Button Content="Either" Click="ScopeAny_Click" Margin="0,0,0,5" Padding="0,4"/>
                <Button Content="SQL Server only" Click="ScopeSql_Click" Margin="0,0,0,5" Padding="0,4"/>
                <Button Content="Oracle only" Click="ScopeOracle_Click" Margin="0,0,0,5" Padding="0,4"/>

                <Separator Margin="0,8"/>
                <TextBlock Text="Library" FontWeight="Bold" Margin="0,0,0,6"
                           Foreground="{DynamicResource Brush.Text}"/>
                <Button Content="Export selected…" Click="Export_Click" Margin="0,0,0,5" Padding="0,4"/>
                <Button Content="Import .sql…" Click="Import_Click" Margin="0,0,0,5" Padding="0,4"/>
            </StackPanel>
        </Border>

        <!-- ===== list + preview ===== -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="3*" MinHeight="140"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="2*" MinHeight="90"/>
            </Grid.RowDefinitions>

            <DataGrid x:Name="Grid" Grid.Row="0" AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" CanUserSortColumns="True"
                      SelectionMode="Extended" SelectionUnit="FullRow"
                      HeadersVisibility="Column"
                      SelectionChanged="Grid_SelectionChanged"
                      MouseDoubleClick="Grid_DoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2.2*"/>
                    <DataGridTextColumn Header="Runs against" Binding="{Binding ScopeLabel}" Width="1.1*"/>
                    <DataGridTextColumn Header="Tags" Binding="{Binding Tags}" Width="1.6*"/>
                    <DataGridTextColumn Header="Updated" Binding="{Binding UpdatedLocal}" Width="1.2*"/>
                    <DataGridTextColumn Header="Sync" Binding="{Binding StatusLabel}" Width="1.1*"/>
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"
                          Background="{DynamicResource Brush.Border}"/>

            <TextBox Grid.Row="2" x:Name="PreviewBox" IsReadOnly="True" AcceptsReturn="True"
                     FontFamily="Consolas" FontSize="12" TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     Background="{DynamicResource Brush.EditorBg}"
                     Foreground="{DynamicResource Brush.EditorText}"/>
        </Grid>
    </DockPanel>
</Window>
