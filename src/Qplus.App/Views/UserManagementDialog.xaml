<Window x:Class="Qplus.App.Views.UserManagementDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="User Management" Height="560" Width="780"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Panel}"
        Foreground="{DynamicResource Brush.Text}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="150"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock x:Name="HeaderText" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}"/>
            <Button DockPanel.Dock="Right" Content="Refresh lists" Click="Refresh_Click"
                    HorizontalAlignment="Right" Padding="8,3"/>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <DockPanel Grid.Column="0" Margin="0,0,6,0">
                <TextBlock DockPanel.Dock="Top" Text="Users" Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,4"/>
                <ListBox x:Name="UsersList"/>
            </DockPanel>
            <DockPanel Grid.Column="1" Margin="6,0,0,0">
                <TextBlock DockPanel.Dock="Top" Text="Roles" Foreground="{DynamicResource Brush.Text}" Margin="0,0,0,4"/>
                <ListBox x:Name="RolesList"/>
            </DockPanel>
        </Grid>

        <!-- Create user -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,4">
            <TextBlock Text="New user" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{DynamicResource Brush.Text}"/>
            <TextBox x:Name="NewUserBox" Width="150" Padding="4,3"/>
            <TextBlock Text="Password" VerticalAlignment="Center" Margin="12,0,6,0" Foreground="{DynamicResource Brush.Text}"/>
            <PasswordBox x:Name="NewPwdBox" Width="150" Padding="4,3"/>
            <Button Content="＋ Create user DDL" Click="CreateUser_Click" Margin="10,0,0,0" Padding="8,3"/>
        </StackPanel>

        <!-- Grant / drop / edit -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,4,0,6">
            <Button Content="✎ Edit user…" Click="EditUser_Click" Padding="8,3" Margin="0,0,6,0"
                    ToolTip="Open the full editor: roles, system privileges, quotas and account settings"/>
            <Button Content="＋ New user…" Click="NewUser_Click" Padding="8,3" Margin="0,0,6,0"/>
            <Button Content="Grant selected role → selected user" Click="GrantRole_Click" Padding="8,3" Margin="0,0,6,0"/>
            <Button Content="Drop selected user DDL" Click="DropUser_Click" Padding="8,3"/>
        </StackPanel>

        <TextBox Grid.Row="4" x:Name="PreviewBox" AcceptsReturn="True" IsReadOnly="False"
                 VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12"
                 Background="{DynamicResource Brush.EditorBg}" Foreground="{DynamicResource Brush.EditorText}"
                 ToolTip="Statements you build accumulate here; edit freely before running."/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="0,0,12,0"
                       Foreground="{DynamicResource Brush.Text}"/>
            <Button Content="Open DDL in editor" Click="Ok_Click" Width="150" Margin="4,0" Padding="0,5"/>
            <Button Content="Close" Click="Cancel_Click" Width="90" Margin="4,0" Padding="0,5" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
