# Auto detect text files and perform LF normalization
* text=auto

# Files consumed by Linux tooling must keep LF even when checked out on Windows.
# A Makefile with CRLF breaks GNU Make: the trailing \r ends up inside recipes and
# after line-continuation backslashes.
Makefile      text eol=lf
*.mk          text eol=lf
*.sh          text eol=lf
Dockerfile    text eol=lf
*.service     text eol=lf
